c1ac7796aacc13902c23e4f778753cd9ca9d267c79ab8be4c82a3bc65e0477da:{"__metadata":{"version":0.1},"root":{"steps":[{"step_id":"01KV6219AVRXC4MDYJGBBH9VZY","step_position":[0,0],"config_field_values":[{"config_field_id":"recurrence","value":"[\"DTSTART;TZID=America/Los_Angeles:20260701T072200\\nRRULE:FREQ=DAILY;INTERVAL=1;WKST=MO;COUNT=1\"]"}],"task_id":"shopify::flow::scheduled_time","task_version":"0.1","task_type":"TRIGGER","description":null,"note":null,"name":null},{"step_id":"01KV63HVTS6F5ZPC66HDDNF08X","step_position":[320,200],"config_field_values":[{"config_field_id":"method","value":"GET"},{"config_field_id":"url","value":"https://fakeweather.discountsworkshop.workers.dev/v1/forecast?location=vancouver"},{"config_field_id":"headers","value":"[]"},{"config_field_id":"body","value":""},{"config_field_id":"on_client_error","value":"retry"},{"config_field_id":"on_server_error","value":"retry"}],"task_id":"shopify::flow::send_http","task_version":"2.0","task_type":"ACTION","description":null,"note":null,"name":"Send HTTP request"},{"step_id":"01KV6464ZJD7E479J6J6FFN33Y","step_position":[320,420],"config_field_values":[{"config_field_id":"input","value":"query {\n  shop {\n    name\n  }\n  sendHttpRequest {\n    body\n  }\n}"},{"config_field_id":"script","value":"   export default function main(input) {\n     const snowCodes = [71, 73, 75, 77, 85, 86];\n     let isSnowing = false;\n     try {\n       const data = JSON.parse(input.sendHttpRequest.body);\n       const current = data.current || {};\n       const snowfall = Number(current.snowfall) || 0;\n       const code = Number(current.weather_code);\n       isSnowing = snowfall > 0 || snowCodes.includes(code);\n     } catch {\n       isSnowing = false;\n     }\n     return { isSnowing };\n   }"},{"config_field_id":"output_schema","value":"\"The output of Run Code\"\ntype Output {\n     \"Whether it is currently snowing in the target city\"\n     isSnowing: Boolean!\n   }"}],"task_id":"shopify::flow::run_code","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":"Run code"},{"step_id":"01KV64GY0D0N1NQT1KFN6HZ4ND","step_position":[320,520],"config_field_values":[{"config_field_id":"metafield","value":"{\"namespace\":\"custom\",\"key\":\"is_snowing\",\"type\":\"boolean\"}"},{"config_field_id":"value","value":"{{runCode.isSnowing}}"}],"task_id":"shopify::admin::add_shop_metafield","task_version":"1.0","task_type":"ACTION","description":null,"note":null,"name":null}],"links":[{"from_step_id":"01KV6219AVRXC4MDYJGBBH9VZY","from_port_id":"output","to_step_id":"01KV63HVTS6F5ZPC66HDDNF08X","to_port_id":"input"},{"from_step_id":"01KV63HVTS6F5ZPC66HDDNF08X","from_port_id":"output","to_step_id":"01KV6464ZJD7E479J6J6FFN33Y","to_port_id":"input"},{"from_step_id":"01KV6464ZJD7E479J6J6FFN33Y","from_port_id":"output","to_step_id":"01KV64GY0D0N1NQT1KFN6HZ4ND","to_port_id":"input"}],"patched_fields":[],"variables":[],"note":null,"vertical_layout_enabled":true,"workflow_name":"SnowFlow"}}